---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBar from "../components/CallBar.astro";
import { BOOK_APPOINTMENT_URL } from "../data/site";

export interface Source {
  label: string
  url: string
}

export interface Props {
  title: string
  description: string
  publishDate: string
  updatedDate?: string
  category: string
  readingTime: string
  ogImage?: string
  author?: string
  authorCredentials?: string
  relatedService?: { href: string; label: string }
  sources?: Source[]
  // When used as an MDX layout, Astro nests frontmatter under `frontmatter`
  frontmatter?: {
    title: string
    description: string
    publishDate: string
    updatedDate?: string
    category: string
    readingTime: string
    ogImage?: string
    author?: string
    authorCredentials?: string
    relatedService?: { href: string; label: string }
    sources?: Source[]
  }
}

// Support both direct prop usage and MDX layout frontmatter passthrough
const fm = Astro.props.frontmatter ?? Astro.props
const { title, description, publishDate, updatedDate, category, readingTime, ogImage, author, authorCredentials, relatedService, sources } = fm

const authorName = author ?? 'Dr. Yelena Mikhaylova'
const authorCreds = authorCredentials ?? 'DDS'
const authorSlug = authorName.toLowerCase().replace(/^dr\.\s+/, '').replace(/\s+/g, '-')

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
})

const siteOrigin = 'https://www.thrivedentalny.com'
const currentPath = Astro.url.pathname

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  image: ogImage
    ? (ogImage.startsWith('http') ? ogImage : siteOrigin + ogImage)
    : siteOrigin + '/og-default.jpg',
  datePublished: publishDate,
  dateModified: updatedDate ?? publishDate,
  author: {
    '@type': 'Person',
    name: authorName,
    honorificSuffix: authorCreds,
    jobTitle: 'Dentist',
    url: siteOrigin + '/doctors/' + authorSlug,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Thrive Dental',
    logo: {
      '@type': 'ImageObject',
      url: siteOrigin + '/thrive-dental-logo.png',
      width: 600,
      height: 60,
    },
  },
  url: siteOrigin + currentPath,
  mainEntityOfPage: { '@type': 'WebPage', '@id': siteOrigin + currentPath },
  isPartOf: { '@type': 'WebSite', '@id': siteOrigin + '/#website' },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteOrigin + '/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: siteOrigin + '/blog' },
    { '@type': 'ListItem', position: 3, name: title, item: siteOrigin + currentPath },
  ],
}
---

<Base title={title} description={description} ogImage={ogImage}>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Article hero -->
  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(2.5rem, 5vw, 4rem);">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/3 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-brand-100/50 blur-[90px]"></div>
    </div>
    <div class="container-slim">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-1.5 text-[12px] font-medium text-slate-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand-600 no-underline transition-colors">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        <a href="/blog" class="hover:text-brand-600 no-underline transition-colors">Blog</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-600 truncate max-w-[200px]">{category}</span>
      </nav>

      <div class="max-w-3xl">
        <div class="mb-5 flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3.5 py-1.5 text-[11px] font-black uppercase tracking-[0.2em] text-brand-700">
            <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
            {category}
          </span>
          <span class="text-[13px] text-slate-400">{readingTime}</span>
        </div>
        <h1 class="display-1 mb-5">{title}</h1>
        <p class="text-[17px] leading-relaxed text-slate-500 mb-6">{description}</p>
        <div class="flex items-center gap-3">
          <div class="flex h-9 w-9 items-center justify-center rounded-full bg-brand-100 text-[11px] font-black text-brand-700">
            {authorName.split(' ').filter(w => !w.startsWith('Dr')).map(w => w[0]).join('').slice(0,2)}
          </div>
          <div>
            <a href={`/doctors/${authorSlug}`} class="text-sm font-semibold text-slate-700 hover:text-brand-600 no-underline transition-colors">
              {authorName}, {authorCreds}
            </a>
            <p class="text-xs text-slate-400">
              Published {formattedDate}
              {updatedDate && updatedDate !== publishDate && (
                <> · Updated {new Date(updatedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</>
              )}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article body -->
  <article class="bg-white py-16">
    <div class="container-slim">
      <div class="mx-auto max-w-3xl prose prose-slate prose-lg
        prose-headings:font-display prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-slate-600 prose-p:leading-relaxed
        prose-a:text-brand-600 prose-a:no-underline hover:prose-a:text-brand-700
        prose-strong:text-slate-800
        prose-ul:text-slate-600 prose-li:my-1
        prose-blockquote:border-brand-400 prose-blockquote:bg-brand-50/50 prose-blockquote:rounded-r-xl prose-blockquote:py-1">
        <slot />
      </div>

      <!-- Related service link -->
      {relatedService && (
        <div class="mx-auto mt-12 max-w-3xl rounded-2xl border border-brand-100 bg-[#f7f3e8] p-6 flex items-center justify-between gap-4">
          <div>
            <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-brand-500 mb-1">Related Service</p>
            <a href={relatedService.href} class="font-display text-lg font-semibold text-slate-900 hover:text-brand-600 no-underline transition-colors">{relatedService.label}</a>
          </div>
          <a href={relatedService.href} class="shrink-0 inline-flex items-center gap-1.5 rounded-full bg-brand-500 px-5 py-2.5 text-sm font-bold text-white hover:bg-brand-400 no-underline transition-colors">
            Learn more
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      )}

      <!-- Sources / citations -->
      {sources && sources.length > 0 && (
        <div class="mx-auto mt-10 max-w-3xl border-t border-slate-100 pt-6">
          <p class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-400 mb-3">Sources & Further Reading</p>
          <ul class="flex flex-col gap-1.5">
            {sources.map((s: Source) => (
              <li class="text-[13px]">
                <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-brand-600 hover:text-brand-700 no-underline transition-colors">{s.label} ↗</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- CTA -->
      <div class="mx-auto mt-16 max-w-3xl rounded-2xl bg-brand-700 p-8 text-white">
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-brand-200 mb-3">Ready to take the next step?</p>
        <h2 class="font-display text-2xl font-bold mb-3">Schedule your appointment at Thrive Dental.</h2>
        <p class="text-white/75 text-sm mb-6">Serving Bayside, Flushing, Douglaston, Little Neck, and all of Queens. New patients always welcome.</p>
        <div class="flex flex-wrap gap-3">
          <a
            href={BOOK_APPOINTMENT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-bold text-brand-700 hover:bg-sand-50 no-underline transition-colors"
          >
            Book Appointment
          </a>
          <a
            href="tel:+1-718-225-6677"
            class="inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/10 px-6 py-3 text-sm font-semibold text-white hover:bg-white/20 no-underline transition-colors"
          >
            (718) 225-6677
          </a>
        </div>
      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
