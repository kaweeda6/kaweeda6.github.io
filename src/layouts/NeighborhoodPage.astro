---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBar from "../components/CallBar.astro";
import { BOOK_APPOINTMENT_URL } from "../data/site";

export interface ServiceLink {
  href: string
  label: string
}

export interface Props {
  title: string
  description: string
  neighborhood: string
  borough?: string
  distanceNote: string   // e.g. "just 8 minutes from Flushing"
  blurb: string          // 2-3 sentence neighborhood-specific intro
  landmarks: string[]    // e.g. ["near the LIRR Flushing Main St stop"]
  serviceLinks?: ServiceLink[]  // service+location combo pages for this neighborhood
  noIndex?: boolean      // set true on thin service+location combo pages
}

const { title, description, neighborhood, borough = 'Queens', distanceNote, blurb, landmarks, serviceLinks = [], noIndex } = Astro.props

const siteOrigin = 'https://www.thrivedentalny.com'
const currentPath = Astro.url.pathname

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  '@id': siteOrigin + '/#dentist',
  name: 'Thrive Dental',
  url: siteOrigin + '/',
  telephone: '+17182256677',
  priceRange: '$$',
  logo: siteOrigin + '/thrive-dental-logo.png',
  image: siteOrigin + '/og-default.jpg',
  sameAs: [
    'https://www.yelp.com/biz/thrive-dental-bayside',
    'https://www.facebook.com/thrivedentalny',
  ],
  address: {
    '@type': 'PostalAddress',
    streetAddress: '41-02 Bell Blvd',
    addressLocality: 'Bayside',
    addressRegion: 'NY',
    postalCode: '11361',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 40.7628,
    longitude: -73.7712,
  },
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Tuesday',   opens: '09:00', closes: '19:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Wednesday', opens: '09:00', closes: '17:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Thursday',  opens: '09:00', closes: '18:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Saturday',  opens: '09:00', closes: '15:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'https://schema.org/Sunday',    opens: '09:00', closes: '15:00' },
  ],
  medicalSpecialty: 'Dentistry',
  areaServed: [
    { '@type': 'City', name: neighborhood },
    { '@type': 'City', name: 'Bayside' },
    { '@type': 'AdministrativeArea', name: 'Queens, New York' },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: 4.9,
    reviewCount: 500,
    bestRating: 5,
    worstRating: 1,
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteOrigin + '/' },
    { '@type': 'ListItem', position: 2, name: `Dentist in ${neighborhood}, ${borough}`, item: siteOrigin + currentPath },
  ],
}

const services = [
  { label: 'General Dentistry',   href: '/services/general-dentistry' },
  { label: 'Teeth Cleaning',      href: '/services/dental-cleanings' },
  { label: 'Dental Implants',     href: '/services/dental-implants' },
  { label: 'Invisalign®',         href: '/services/invisalign' },
  { label: 'Porcelain Veneers',   href: '/services/porcelain-veneers' },
  { label: 'Teeth Whitening',     href: '/services/teeth-whitening' },
  { label: 'Emergency Dentistry', href: '/services/emergency-dentistry' },
  { label: 'Dental Crowns',       href: '/services/dental-crowns' },
  { label: 'Root Canal',          href: '/services/root-canal-therapy' },
  { label: 'Pediatric Dentistry', href: '/services/pediatric-dentistry' },
  { label: 'Gum Disease',         href: '/services/gum-disease-treatment' },
  { label: 'Dental Bonding',      href: '/services/dental-bonding' },
]
---

<Base title={title} description={description} noIndex={Astro.props.noIndex ?? false}>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-48 -left-24 h-[640px] w-[640px] rounded-full bg-brand-100/40 blur-[120px]"></div>
      <div class="absolute top-1/2 right-0 h-[400px] w-[400px] -translate-y-1/2 rounded-full bg-brand-50/60 blur-[80px]"></div>
    </div>
    <div class="container-slim">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-1.5 text-[12px] font-medium text-slate-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-brand-600 no-underline transition-colors">Home</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-600">Dentist in {neighborhood}, {borough}</span>
      </nav>

      <div class="max-w-2xl">
        <span class="mb-5 inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3.5 py-1.5 text-[11px] font-black uppercase tracking-[0.2em] text-brand-700">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          Serving {neighborhood}
        </span>
        <h1 class="display-1 mb-5">Dentist Near {neighborhood}, {borough}</h1>
        <p class="text-[17px] leading-relaxed text-slate-500 mb-8">
          {blurb}
        </p>
        <div class="flex flex-wrap gap-3 mb-8">
          <a
            href={BOOK_APPOINTMENT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-7 py-4 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 hover:-translate-y-px transition-all no-underline"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book Appointment
          </a>
          <a
            href="tel:+1-718-225-6677"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-7 py-4 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 hover:-translate-y-px transition-all no-underline"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.42 2 2 0 0 1 3.93 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (718) 225-6677
          </a>
        </div>
        {landmarks.length > 0 && (
          <ul class="flex flex-wrap gap-2">
            {landmarks.map((l) => (
              <li class="inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-3 py-1 text-[12px] text-slate-500">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                {l}
              </li>
            ))}
          </ul>
        )}
      </div>
    </div>
  </section>

  <!-- Why patients from this neighborhood choose us -->
  <section class="bg-sand-100 py-20">
    <div class="container-slim grid gap-12 lg:grid-cols-2 lg:items-start">
      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Why Choose Thrive Dental</p>
        <h2 class="display-2 mb-5">Your neighborhood deserves better dental care.</h2>
        <p class="text-slate-500 leading-relaxed mb-6">
          Thrive Dental is {distanceNote}. We've built a practice where patients from {neighborhood} and all of Queens feel genuinely welcome — not just another appointment on the schedule.
        </p>
        <ul class="space-y-4">
          {[
            { icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`, title: 'Experienced Dental Team', desc: 'Three dedicated dentists — Dr. Mikhaylova, Dr. Hart, and Dr. Saleh — each with deep expertise across general, cosmetic, and restorative care.' },
            { icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`, title: 'Same-Day Emergency Appointments', desc: 'We reserve daily slots for urgent care. Dental pain doesn\'t wait, and neither should you.' },
            { icon: `<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`, title: 'Advanced Technology', desc: 'iTero digital scanning, 3D cone beam imaging, and laser dentistry mean more precise care and fewer surprises.' },
            { icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>`, title: 'All Ages Welcome', desc: 'From kids\' first checkups to full-mouth restorations for adults — we treat the whole family under one roof.' },
          ].map((item) => (
            <li class="flex gap-4 items-start">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-600">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} aria-hidden="true" />
              </div>
              <div>
                <p class="font-semibold text-slate-900 text-sm">{item.title}</p>
                <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info card -->
      <div class="rounded-2xl border border-brand-200/50 bg-sand-50 p-8 lg:sticky lg:top-28">
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-5">Visit Our Office</p>
        <div class="space-y-4 mb-6">
          <div class="flex items-start gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-brand-500" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p class="font-semibold text-slate-900 text-sm">41-02 Bell Blvd, Bayside NY 11361</p>
              <a href="https://maps.app.goo.gl/yz2gipKBB3Dfp7Tg9" target="_blank" rel="noopener noreferrer" class="text-xs text-brand-600 hover:text-brand-700 no-underline">Get directions →</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-brand-500" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.42 2 2 0 0 1 3.93 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+1-718-225-6677" class="font-semibold text-slate-900 text-sm hover:text-brand-600 no-underline transition-colors">(718) 225-6677</a>
          </div>
        </div>
        <dl class="space-y-2 mb-6 border-t border-brand-200/60 pt-5">
          {[
            { days: 'Tuesday', hours: '9 AM – 7 PM' },
            { days: 'Wednesday', hours: '9 AM – 5 PM' },
            { days: 'Thursday', hours: '9 AM – 6 PM' },
            { days: 'Sat – Sun', hours: '9 AM – 3 PM' },
          ].map((row) => (
            <div class="flex justify-between text-sm">
              <dt class="text-slate-500">{row.days}</dt>
              <dd class="font-medium text-slate-700">{row.hours}</dd>
            </div>
          ))}
          <div class="flex justify-between text-sm"><dt class="text-slate-400">Mon &amp; Fri</dt><dd class="text-slate-400 line-through">Closed</dd></div>
        </dl>
        <a
          href={BOOK_APPOINTMENT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-center rounded-full bg-brand-500 px-5 py-3 text-sm font-bold text-white hover:bg-brand-400 no-underline transition-colors"
        >
          Book Your Appointment
        </a>
      </div>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-sand-50 py-20">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">What We Offer</p>
      <h2 class="display-2 mb-3">Comprehensive dental care for {neighborhood} patients.</h2>
      <p class="text-slate-500 mb-10 max-w-xl">From your family's routine cleanings to full smile transformations — everything under one roof in Bayside, Queens.</p>
      <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4">
        {services.map((svc) => (
          <a
            href={svc.href}
            class="rounded-xl border border-brand-200/50 bg-white px-4 py-3.5 text-sm font-medium text-slate-700 hover:border-brand-400 hover:text-brand-700 hover:bg-brand-50 no-underline transition-all text-center"
          >
            {svc.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Service+location combos for this neighborhood -->
  {serviceLinks.length > 0 && (
    <section class="bg-sand-100 py-14 border-t border-brand-100/50">
      <div class="container-slim">
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Specific Services in {neighborhood}</p>
        <h2 class="display-2 mb-3">Treatments for {neighborhood} patients.</h2>
        <p class="text-slate-500 mb-8 max-w-xl">Explore detailed information about specific dental treatments available to {neighborhood} residents at our Bayside practice.</p>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {serviceLinks.map((link) => (
            <a href={link.href} class="group flex items-center justify-between rounded-2xl border border-brand-200/40 bg-sand-50/70 px-6 py-4 hover:border-brand-400 hover:bg-brand-50/40 transition-all no-underline">
              <span class="text-[14px] font-semibold text-slate-700 group-hover:text-brand-700 transition-colors">{link.label}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0 text-slate-300 group-hover:text-brand-500 transition-colors"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Map + CTA -->
  <section class="bg-sand-100 py-20">
    <div class="container-slim grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Easy to Reach</p>
        <h2 class="display-2 mb-5">Conveniently located for {neighborhood} residents.</h2>
        <p class="text-slate-500 leading-relaxed mb-6">
          Our office at 41-02 Bell Blvd in Bayside is {distanceNote}. We offer free parking and are accessible by public transit.
        </p>
        <p class="text-slate-500 leading-relaxed mb-8">
          New patients are always welcome. We accept most major insurance plans and offer flexible payment options to make quality dental care accessible for your family.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={BOOK_APPOINTMENT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 no-underline transition-all"
          >
            Book Online
          </a>
          <a
            href="https://maps.app.goo.gl/yz2gipKBB3Dfp7Tg9"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 no-underline transition-all"
          >
            Get Directions
          </a>
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-[0_4px_24px_rgba(0,0,0,0.07)]" style="aspect-ratio: 4/3;">
        <iframe
          title="Thrive Dental — 41-02 Bell Blvd, Bayside NY"
          class="h-full w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3021.937217493749!2d-73.77362692397173!3d40.76340557138596!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c28a7552b55921%3A0xb59d5e47f359d011!2sThrive%20Dental!5e0!3m2!1sen!2sus!4v1772506008906!5m2!1sen!2sus"
        ></iframe>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
