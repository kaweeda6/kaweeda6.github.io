---
import Base from "./Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CallBar from "../components/CallBar.astro";
import { BOOK_APPOINTMENT_URL } from "../data/site";

export interface FAQ {
  q: string
  a: string
}

export interface Props {
  // SEO
  title: string
  description: string
  // Service details
  service: string           // e.g. "Invisalign®"
  serviceHref: string       // e.g. "/services/invisalign"
  serviceCategory: string   // e.g. "Orthodontics"
  // Location details
  location: string          // e.g. "Whitestone"
  borough?: string          // defaults to "Queens"
  distanceNote: string      // e.g. "just 8 minutes from Whitestone via the Whitestone Expressway"
  // Content
  h1?: string               // defaults to "{service} in {location}, {borough}"
  intro: string             // 2–3 sentences: why this service matters here
  whyUs?: string            // optional extra paragraph in Why Us
  faq?: FAQ[]
  // Related
  relatedServices?: Array<{ href: string; label: string }>
}

const {
  title, description,
  service, serviceHref, serviceCategory,
  location, borough = 'Queens',
  distanceNote,
  h1 = `${service} in ${location}, ${borough}`,
  intro, whyUs,
  faq = [],
  relatedServices = [],
} = Astro.props

const siteOrigin = 'https://www.thrivedentalny.com'
const currentPath = Astro.url.pathname

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'Dentist',
  '@id': siteOrigin + '/#dentist',
  name: 'Thrive Dental',
  url: siteOrigin + '/',
  telephone: '+17182256677',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '41-02 Bell Blvd',
    addressLocality: 'Bayside',
    addressRegion: 'NY',
    postalCode: '11361',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 40.7628, longitude: -73.7712 },
  areaServed: [
    { '@type': 'City', name: location },
    { '@type': 'City', name: 'Bayside' },
    { '@type': 'Borough', name: 'Queens' },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: 4.9,
    reviewCount: 500,
    bestRating: 5,
    worstRating: 1,
  },
}

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteOrigin + '/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: siteOrigin + '/services' },
    { '@type': 'ListItem', position: 3, name: service, item: siteOrigin + serviceHref },
    { '@type': 'ListItem', position: 4, name: `${service} near ${location}`, item: siteOrigin + currentPath },
  ],
}
---

<Base title={title} description={description} noIndex={true}>
  <Fragment slot="header"><Header /></Fragment>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-48 -left-24 h-[640px] w-[640px] rounded-full bg-brand-100/40 blur-[120px]"></div>
      <div class="absolute top-1/2 right-0 h-[400px] w-[400px] -translate-y-1/2 rounded-full bg-brand-50/60 blur-[80px]"></div>
    </div>

    <div class="container-slim">
      <!-- Breadcrumb -->
      <nav class="mb-6 flex items-center gap-1.5 flex-wrap text-[12px] font-medium text-slate-400" aria-label="Breadcrumb">
        <a href="/services" class="hover:text-brand-600 no-underline transition-colors">Services</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        <a href={serviceHref} class="hover:text-brand-600 no-underline transition-colors">{service}</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        <span class="text-slate-600">{location}</span>
      </nav>

      <div class="max-w-2xl">
        <span class="mb-5 inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3.5 py-1.5 text-[11px] font-black uppercase tracking-[0.2em] text-brand-700">
          <span class="h-1.5 w-1.5 rounded-full bg-brand-500"></span>
          {serviceCategory} · Serving {location}
        </span>

        <h1 class="display-1 mb-5">{h1}</h1>
        <p class="text-[17px] leading-relaxed text-slate-500 mb-8">{intro}</p>

        <!-- Trust bar -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-2 mb-8">
          <div class="flex items-center gap-2">
            <span class="text-amber-400 text-sm">★★★★★</span>
            <span class="text-[13px] font-semibold text-slate-700">4.9 · 500+ Reviews</span>
          </div>
          <span class="hidden sm:block h-3.5 w-px bg-slate-200"></span>
          <div class="flex items-center gap-1.5 text-[13px] text-slate-500">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-500"><polyline points="20 6 9 17 4 12"/></svg>
            Same-day available
          </div>
          <span class="hidden sm:block h-3.5 w-px bg-slate-200"></span>
          <div class="flex items-center gap-1.5 text-[13px] text-slate-500">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-brand-500"><polyline points="20 6 9 17 4 12"/></svg>
            Most insurance accepted
          </div>
        </div>

        <div class="flex flex-wrap gap-3">
          <a
            href={BOOK_APPOINTMENT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-7 py-4 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 hover:-translate-y-px transition-all no-underline"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Book Appointment
          </a>
          <a
            href="tel:+1-718-225-6677"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-7 py-4 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 hover:-translate-y-px transition-all no-underline"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.42 2 2 0 0 1 3.93 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (718) 225-6677
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WHY THRIVE FOR THIS SERVICE
  ═══════════════════════════════════════════ -->
  <section class="bg-white py-20">
    <div class="container-slim grid gap-12 lg:grid-cols-2 lg:items-start">

      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Why Choose Thrive Dental</p>
        <h2 class="display-2 mb-5">The {location}-area practice that gets it right.</h2>
        <p class="text-slate-500 leading-relaxed mb-5">
          Thrive Dental is {distanceNote}. Our board-certified team delivers {service} with the same precision and care we'd want for our own families — no shortcuts, no unnecessary upsells.
        </p>
        {whyUs && (
          <p class="text-slate-500 leading-relaxed mb-6">{whyUs}</p>
        )}
        <ul class="space-y-4 mb-8">
          {[
            { title: 'Board-Certified Doctors', desc: `Dr. Mikhaylova, Dr. Hart, and Dr. Saleh — each with advanced training across ${service} and related treatments.` },
            { title: 'Advanced Technology', desc: 'iTero digital scanning, 3D cone beam imaging, and laser dentistry for precision care with fewer appointments.' },
            { title: 'Transparent Pricing', desc: 'We provide full treatment plans with itemized costs before you commit. No surprise invoices.' },
            { title: 'Most Insurance Accepted', desc: 'We work with Delta Dental, MetLife, Aetna, Guardian, Cigna, and most major PPO plans.' },
          ].map((item) => (
            <li class="flex gap-4 items-start">
              <div class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-brand-600"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <div>
                <span class="text-[14px] font-semibold text-slate-800">{item.title}</span>
                <span class="text-[13px] text-slate-400"> — {item.desc}</span>
              </div>
            </li>
          ))}
        </ul>
        <a href={serviceHref} class="inline-flex items-center gap-2 text-sm font-bold text-brand-600 no-underline hover:text-brand-700 transition-colors">
          Learn more about our {service} service
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Info card -->
      <div class="rounded-2xl border border-slate-100 bg-sand-50 p-8 lg:sticky lg:top-28">
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-5">Visit Our Office</p>
        <div class="space-y-4 mb-6">
          <div class="flex items-start gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-brand-500" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <div>
              <p class="font-semibold text-slate-900 text-sm">41-02 Bell Blvd, Bayside NY 11361</p>
              <p class="text-xs text-slate-500">{distanceNote}</p>
              <a href="https://maps.app.goo.gl/yz2gipKBB3Dfp7Tg9" target="_blank" rel="noopener noreferrer" class="text-xs text-brand-600 hover:text-brand-700 no-underline">Get directions →</a>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-brand-500" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.42 2 2 0 0 1 3.93 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <a href="tel:+1-718-225-6677" class="font-semibold text-slate-900 text-sm hover:text-brand-600 no-underline transition-colors">(718) 225-6677</a>
          </div>
        </div>
        <dl class="space-y-2 mb-6 border-t border-slate-200 pt-5">
          {[
            { days: 'Tuesday', hours: '9 AM – 7 PM' },
            { days: 'Wednesday', hours: '9 AM – 5 PM' },
            { days: 'Thursday', hours: '9 AM – 6 PM' },
            { days: 'Sat – Sun', hours: '9 AM – 3 PM' },
          ].map((row) => (
            <div class="flex justify-between text-sm">
              <dt class="text-slate-500">{row.days}</dt>
              <dd class="font-medium text-slate-700">{row.hours}</dd>
            </div>
          ))}
          <div class="flex justify-between text-sm"><dt class="text-slate-400">Mon &amp; Fri</dt><dd class="text-slate-400 line-through">Closed</dd></div>
        </dl>
        <a
          href={BOOK_APPOINTMENT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="block text-center rounded-full bg-brand-500 px-5 py-3 text-sm font-bold text-white hover:bg-brand-400 no-underline transition-colors"
        >
          Book Your {service} Consultation
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ — cream bg
  ═══════════════════════════════════════════ -->
  {faq.length > 0 && (
    <section class="bg-sand-50 py-20">
      <div class="container-slim">
        <div class="grid gap-14 lg:grid-cols-[1fr_1.4fr] lg:gap-20 items-start">
          <div class="lg:sticky lg:top-28">
            <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-5">FAQ</p>
            <h2 class="display-2 mb-5">Questions from {location} patients.</h2>
            <p class="text-[16px] leading-relaxed text-slate-500 mb-8">
              Don't see your question here? Call us — we're happy to answer before your visit.
            </p>
            <a
              href="tel:+1-718-225-6677"
              class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all no-underline"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.95 3.42 2 2 0 0 1 3.93 1.25h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              Call (718) 225-6677
            </a>
          </div>
          <div class="space-y-3">
            {faq.map((item) => (
              <details class="group overflow-hidden rounded-2xl border border-slate-200 bg-white">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-6 font-semibold text-[15px] text-slate-900 hover:text-brand-700 transition-colors select-none">
                  <span>{item.q}</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mt-0.5 shrink-0 text-slate-400 transition-transform duration-200 group-open:rotate-45">
                    <path d="M12 5v14M5 12h14"/>
                  </svg>
                </summary>
                <div class="border-t border-slate-100 px-6 pb-6 pt-4">
                  <p class="text-[14px] leading-relaxed text-slate-500">{item.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       RELATED SERVICES
  ═══════════════════════════════════════════ -->
  {relatedServices.length > 0 && (
    <section class="bg-white py-14 border-t border-slate-100">
      <div class="container-slim">
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-6">Also at Thrive Dental</p>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {relatedServices.map((r) => (
            <a href={r.href} class="group flex items-center justify-between rounded-2xl border border-brand-200/40 bg-sand-50/70 px-6 py-4 hover:border-brand-400 hover:bg-brand-50/40 transition-all no-underline">
              <span class="text-[14px] font-semibold text-slate-700 group-hover:text-brand-700 transition-colors">{r.label}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0 text-slate-300 group-hover:text-brand-500 transition-colors"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ═══════════════════════════════════════════
       MAP + CTA
  ═══════════════════════════════════════════ -->
  <section class="bg-sand-50 py-20">
    <div class="container-slim grid gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Easy to Reach from {location}</p>
        <h2 class="display-2 mb-5">Conveniently located for {location} residents.</h2>
        <p class="text-slate-500 leading-relaxed mb-6">
          Our office at 41-02 Bell Blvd in Bayside is {distanceNote}. Free parking is available and we're accessible by public transit.
        </p>
        <p class="text-slate-500 leading-relaxed mb-8">
          New patients are always welcome — no referral needed. We accept most major insurance plans and offer CareCredit and Sunbit financing.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={BOOK_APPOINTMENT_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 no-underline transition-all"
          >
            Book Online
          </a>
          <a
            href="https://maps.app.goo.gl/yz2gipKBB3Dfp7Tg9"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 hover:bg-slate-50 no-underline transition-all"
          >
            Get Directions
          </a>
        </div>
      </div>
      <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-[0_4px_24px_rgba(0,0,0,0.07)]" style="aspect-ratio: 4/3;">
        <iframe
          title="Thrive Dental — 41-02 Bell Blvd, Bayside NY"
          class="h-full w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3021.937217493749!2d-73.77362692397173!3d40.76340557138596!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c28a7552b55921%3A0xb59d5e47f359d011!2sThrive%20Dental!5e0!3m2!1sen!2sus!4v1772506008906!5m2!1sen!2sus"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
