---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CallBar from "../../components/CallBar.astro";
import ReviewsCarousel from "../../components/ReviewsCarousel.astro";
import { Image } from "astro:assets";
import docImg from "../../assets/team/yelena-mikhaylova.jpg";
import { BOOK_APPOINTMENT_URL } from "../../data/site";

const doc = {
  name: 'Dr. Yelena Mikhaylova',
  credentials: 'DDS',
  title: 'Founder & Clinical Director',
  bio: 'With over a decade of experience, Dr. Mikhaylova combines clinical precision with an artistic eye to create healthy, confident smiles.',
  img: docImg,
  slug: 'yelena-mikhaylova'
}
---

<Base
  title="Dr. Yelena Mikhaylova, DDS | Bayside NY Cosmetic Dentist"
  description="Dr. Yelena Mikhaylova, DDS — founder of Thrive Dental in Bayside, NY. NYU-trained, Invisalign® Gold Plus Provider, and expert in cosmetic dentistry, dental implants, and full-mouth rehabilitation."
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Hero spacing now scales with viewport height for mobile comfort -->
  <section class="relative bg-sand-50 overflow-hidden" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <!-- Background Decor -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-24 left-1/4 h-[500px] w-[500px] rounded-full bg-brand-100/40 blur-[100px]"></div>
      <div class="absolute bottom-0 right-0 h-[400px] w-[400px] rounded-full bg-brand-50/60 blur-[80px]"></div>
    </div>

    <div class="container-wide">
      <!-- Desktop: wider canvas with fixed image column for stronger visual hierarchy -->
      <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16 xl:gap-20">
        
        <!-- Photo Side -->
        <div class="relative lg:order-1 lg:col-span-6">
          <div class="relative overflow-hidden rounded-[3rem] shadow-2xl bg-brand-50 w-full" style="aspect-ratio: 4/5;">
            <Image 
              src={doc.img} 
              alt={doc.name} 
              class="h-full w-full object-cover object-top"
              width={900}
              height={1125}
              loading="eager"
            />
            </div>
            </div>
        <!-- Info Side -->
        <div class="lg:order-2 lg:col-span-6">
          <p class="text-[11px] font-black uppercase tracking-[0.3em] text-gold-700 mb-6">Founder & Clinical Director</p>
          <h1 class="display-1 text-slate-900 leading-[1.05] tracking-tight mb-6">{doc.name}</h1>
          
          <div class="flex items-center gap-3 mb-12">
            <span class="h-px w-8 bg-brand-400"></span>
            <p class="text-[14px] font-bold text-slate-400 uppercase tracking-[0.2em] leading-relaxed">
              DDS • Invisalign® Gold Plus Provider
            </p>
          </div>
          
          <div class="space-y-8">
             <p class="text-xl text-slate-700 leading-relaxed mb-6">
               {doc.bio}
             </p>
             
             <div class="prose prose-slate max-w-none prose-p:text-[17px] prose-p:leading-relaxed prose-p:text-slate-600 space-y-6">
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">Education &amp; Training</h2>
               <p>
                 Driven by her enthusiasm for the profession, Dr. Mikhaylova pursued her education at <strong>New York University School of Dentistry</strong>, where she earned her dental degree. Building upon her foundational knowledge, she went on to complete advanced training in aesthetic and surgical dentistry as the chief resident at <strong>Woodhull Medical Center-NYU Langone Health</strong> in New York City.
               </p>
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">Areas of Focus</h2>
               <p>
                 In addition to her exceptional qualifications, Dr. Mikhaylova is dedicated to continuous learning and professional growth. She actively participates in lectures and workshops across New York, consistently expanding her expertise in cosmetic dentistry and full-mouth rehabilitation treatments. Her commitment to excellence is reflected in her certification in implant restoration and full-mouth rehabilitation, as well as her status as an <strong>Invisalign® Gold Plus Provider</strong>.
               </p>
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">About Dr. Mikhaylova</h2>
               <p>
                 Currently residing in Long Island with her husband, son Elan, and daughter Talia, she continues to make a positive impact on the oral health and smiles of her patients.
               </p>
             </div>
          </div>

          <div class="mt-14 flex items-center gap-3">
            <a
              href={BOOK_APPOINTMENT_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-3 sm:px-8 sm:py-4 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 transition-all no-underline"
            >
              Book Appointment
            </a>
            <a
              href="tel:+1-718-225-6677"
              class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-3 sm:px-8 sm:py-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-all no-underline"
            >
              (718) 225-6677
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  

  <!-- Structured data: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Dr. Yelena Mikhaylova',
    honorificPrefix: 'Dr.',
    honorificSuffix: 'DDS',
    jobTitle: 'Founder & Clinical Director',
    description: 'NYU-trained dentist and Invisalign® Gold Plus Provider specializing in cosmetic dentistry, dental implants, and full-mouth rehabilitation at Thrive Dental in Bayside, Queens, NY.',
    image: 'https://www.thrivedentalny.com/og-default.jpg',
    url: 'https://www.thrivedentalny.com/doctors/yelena-mikhaylova',
    sameAs: [
      'https://www.healthgrades.com/dentist/dr-yelena-mikhaylova',
    ],
    alumniOf: [
      { '@type': 'EducationalOrganization', name: 'New York University College of Dentistry' },
      { '@type': 'EducationalOrganization', name: 'Woodhull Medical Center – NYU Langone Health' },
    ],
    hasOccupation: {
      '@type': 'Occupation',
      name: 'Dentist',
    },
    worksFor: {
      '@type': 'Dentist',
      '@id': 'https://www.thrivedentalny.com/#dentist',
      name: 'Thrive Dental',
    },
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.thrivedentalny.com/' },
      { '@type': 'ListItem', position: 2, name: 'Our Doctors', item: 'https://www.thrivedentalny.com/doctors' },
      { '@type': 'ListItem', position: 3, name: 'Dr. Yelena Mikhaylova', item: 'https://www.thrivedentalny.com/doctors/yelena-mikhaylova' },
    ],
  })} />

  <Fragment slot="reviews-carousel"><ReviewsCarousel /></Fragment>
  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
