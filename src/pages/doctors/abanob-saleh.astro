---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CallBar from "../../components/CallBar.astro";
import ReviewsCarousel from "../../components/ReviewsCarousel.astro";
import { Image } from "astro:assets";
import docImg from "../../assets/team/abanob-saleh.jpg";
import { BOOK_APPOINTMENT_URL } from "../../data/site";

const doc = {
  name: 'Dr. Abanob Saleh',
  credentials: 'DMD',
  title: 'Dentist',
  bio: 'A highly trained general dentist committed to providing comprehensive, holistic dental care using the most advanced techniques available.',
  img: docImg,
  slug: 'abanob-saleh'
}
---

<Base
  title="Dr. Abanob Saleh, DMD | Restorative & Emergency Dentist in Bayside, NY"
  description="Dr. Abanob Saleh is a DMD at Thrive Dental in Bayside, Queens NY. Expert in advanced restorative and emergency dental care. Graduate of NYU School of Dentistry. New patients welcome."
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Section with massive padding-top to clear the fixed navigation bar -->
  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <!-- Background Decor -->
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-24 left-1/4 h-[500px] w-[500px] rounded-full bg-brand-100/40 blur-[100px]"></div>
      <div class="absolute bottom-0 right-0 h-[400px] w-[400px] rounded-full bg-brand-50/60 blur-[80px]"></div>
    </div>

    <div class="container-wide">
      <div class="grid items-start gap-12 lg:grid-cols-12 lg:gap-16 xl:gap-20">
        
        <!-- Photo Side -->
        <div class="relative lg:order-1 lg:col-span-6">
          <div class="relative overflow-hidden rounded-[3rem] shadow-2xl bg-brand-50 w-full" style="aspect-ratio: 4/5;">
            <Image 
              src={doc.img} 
              alt={doc.name} 
              class="h-full w-full object-cover object-top"
              width={900}
              height={1125}
              loading="eager"
            />
            </div>
            </div>
        <!-- Info Side -->
        <div class="lg:order-2 lg:col-span-6">
          <p class="text-[11px] font-black uppercase tracking-[0.3em] text-gold-700 mb-6">Our Team</p>
          <h1 class="display-1 text-slate-900 leading-[1.05] tracking-tight mb-6">{doc.name}</h1>
          
          <div class="flex items-center gap-3 mb-12">
            <span class="h-px w-8 bg-brand-400"></span>
            <p class="text-[14px] font-bold text-slate-400 uppercase tracking-[0.2em] leading-relaxed">
              {doc.credentials} • Dentist
            </p>
          </div>
          
          <div class="space-y-8">
             <p class="text-xl text-slate-700 leading-relaxed mb-6">
               Dr. Saleh believes that a comprehensive and holistic approach to dentistry is the best way to achieve the best dental health.
             </p>
             <div class="prose prose-slate max-w-none prose-p:text-[17px] prose-p:leading-relaxed prose-p:text-slate-600">
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">About Dr. Saleh</h2>
               <p>
                 Dr. Abanob Saleh is a highly trained general dentist who is committed to providing comprehensive dental care using the most up-to-date, advanced dentistry available. Dr. Saleh is known for his willingness to get to know his patients personally while also using thorough consultations to get familiar with his patient’s dental needs.
               </p>
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">Education &amp; Training</h2>
               <p>
                 A resident native of Queens, NY, Dr. Saleh currently lives in Long Island. Dr. Saleh graduated from the prestigious Macaulay Honors Program in NYC after which he earned his Doctorate of Dental Medicine at the New York University School of Dentistry in New York City. He then completed his residency at the Northport VA Medical Center where he continued his training in cosmetic and general dentistry.
               </p>
               <h2 class="text-lg font-bold text-slate-800 mt-8 mb-3">Areas of Focus</h2>
               <p>
                 Dr. Saleh is well trained in all aspects of aesthetic and restorative dentistry, including composite restorations, crowns, dental implant restorations, emergency dental care, and full-mouth rehabilitation. Every patient receives precision care tailored to their unique goals.
               </p>
             </div>
          </div>

          <div class="mt-14 flex items-center gap-3">
            <a
              href={BOOK_APPOINTMENT_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-3 sm:px-8 sm:py-4 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 transition-all no-underline"
            >
              Book with Dr. Saleh
            </a>
            <a
              href="tel:+1-718-225-6677"
              class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-5 py-3 sm:px-8 sm:py-4 text-sm font-semibold text-slate-700 hover:bg-slate-50 transition-all no-underline"
            >
              (718) 225-6677
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  

  <!-- Structured data: Person -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Dr. Abanob Saleh',
    honorificPrefix: 'Dr.',
    honorificSuffix: 'DMD',
    jobTitle: 'Dentist',
    description: 'Dr. Abanob Saleh is a highly trained general dentist at Thrive Dental in Bayside, NY, committed to comprehensive and holistic dental health.',
    image: 'https://www.thrivedentalny.com/og-default.jpg',
    url: 'https://www.thrivedentalny.com/doctors/abanob-saleh',
    alumniOf: [
      { '@type': 'EducationalOrganization', name: 'New York University School of Dentistry' },
      { '@type': 'EducationalOrganization', name: 'Northport VA Medical Center' },
    ],
    hasOccupation: {
      '@type': 'Occupation',
      name: 'Dentist',
    },
    worksFor: {
      '@type': 'Dentist',
      '@id': 'https://www.thrivedentalny.com/#dentist',
      name: 'Thrive Dental',
    },
  })} />

  <!-- BreadcrumbList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.thrivedentalny.com/' },
      { '@type': 'ListItem', position: 2, name: 'Our Doctors', item: 'https://www.thrivedentalny.com/doctors' },
      { '@type': 'ListItem', position: 3, name: 'Dr. Abanob Saleh', item: 'https://www.thrivedentalny.com/doctors/abanob-saleh' },
    ],
  })} />

  <Fragment slot="reviews-carousel"><ReviewsCarousel /></Fragment>
  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
