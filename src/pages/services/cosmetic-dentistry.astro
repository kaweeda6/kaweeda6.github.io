---
import ServicePage from "../../layouts/ServicePage.astro";
const services = [
  { href: '/services/teeth-whitening',   label: 'Teeth Whitening' },
  { href: '/services/porcelain-veneers', label: 'Porcelain Veneers' },
  { href: '/services/invisalign',        label: 'Invisalign®' },
  { href: '/services/dental-bonding',    label: 'Dental Bonding' },
  { href: '/services/smile-design',      label: 'Smile Design' },
]
---
<ServicePage
  title="Cosmetic Dentistry in Bayside, Queens NY | Thrive Dental"
  description="Cosmetic dentistry in Bayside, Queens NY — teeth whitening, porcelain veneers, Invisalign®, bonding & smile design. Invisalign Gold Plus Provider. Call (718) 225-6677."
  category="Our Services"
  categoryHref="/services"
  h1="Cosmetic Dentistry in Bayside, Queens"
  subtitle="Your smile is the first thing people notice. Our cosmetic treatments are designed to give you the confidence to show it off — naturally, beautifully, and built to last."
  related={[
    { href: '/services/preventive-dentistry',  label: 'Preventive Dentistry' },
    { href: '/services/restorative-dentistry', label: 'Restorative Dentistry' },
    { href: '/services',                       label: 'All Services' },
  ]}
>
  <section class="bg-white py-20">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-6">Cosmetic Services</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a href={s.href} class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-brand-200 hover:shadow-md transition-all no-underline">
            <span class="text-sm font-semibold text-slate-700 group-hover:text-brand-500 transition-colors">{s.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 group-hover:text-brand-500 transition-colors shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</ServicePage>
