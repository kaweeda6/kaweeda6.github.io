---
import ServicePage from "../../layouts/ServicePage.astro";
import heroImg from "../../assets/office/dr_mik_showing_denturess.jpg";
const services = [
  { href: '/services/teeth-whitening',   label: 'Teeth Whitening' },
  { href: '/services/porcelain-veneers', label: 'Porcelain Veneers' },
  { href: '/services/invisalign',        label: 'Invisalign®' },
  { href: '/services/dental-bonding',    label: 'Dental Bonding' },
  { href: '/services/smile-design',      label: 'Smile Design' },
]
---
<ServicePage
  title="Cosmetic Dentistry in Bayside, Queens NY | Thrive Dental"
  description="Cosmetic dentistry in Bayside, Queens NY — veneers, whitening, Invisalign®, bonding & smile design. Invisalign Gold Plus Provider. Call (718) 225-6677."
  category="Our Services"
  categoryHref="/services"
  h1="Cosmetic Dentistry in Bayside, Queens"
  subtitle="Your smile is the first thing people notice. Our cosmetic treatments are designed to give you the confidence to show it off — naturally, beautifully, and built to last."
  heroImg={heroImg}
  overviewTitle="What is cosmetic dentistry — and is it right for you?"
  overviewText="Cosmetic dentistry is the branch of dental care focused on improving the appearance of your teeth, gums, and overall smile. Unlike restorative dentistry, which addresses structural problems like cavities or broken teeth, cosmetic procedures are primarily elective — chosen by patients who want to change the color, shape, size, alignment, or proportion of their teeth. The most common cosmetic concerns we treat are discoloration that doesn't respond to whitening, chips or cracks in the front teeth, uneven or worn edges, gaps between teeth, teeth that are too short or too long, and overall smile asymmetry."
  overviewExtra="Modern cosmetic dentistry is more conservative than ever. Advances in porcelain materials, digital design tools, and minimally invasive bonding techniques mean that today's cosmetic work removes less healthy tooth structure — and delivers better, longer-lasting results — than treatments from a decade ago. At Thrive Dental in Bayside, every cosmetic case starts with a comprehensive consultation where we photograph your smile, use digital smile design software to model potential outcomes, and discuss which treatments match your goals, timeline, and budget. As an Invisalign Gold Plus Provider with hundreds of cosmetic cases in Queens, we're able to handle everything from a simple teeth whitening session to a full smile transformation under one roof — with no referrals needed."
  benefits={[
    {
      icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
      title: 'See Results Before You Commit',
      desc: 'Digital smile design lets you preview your new smile — shape, shade, and proportions — before any tooth is touched.',
    },
    {
      icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
      title: 'Minimally Invasive Options',
      desc: 'From bonding to no-prep veneers, many cosmetic results are achievable with little or no removal of healthy enamel.',
    },
    {
      icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
      title: 'Built to Last',
      desc: 'Quality porcelain veneers last 15–20 years. Professional whitening results last 1–3 years with proper maintenance.',
    },
    {
      icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>`,
      title: 'Gold Plus Invisalign Provider',
      desc: 'We\'ve completed more Invisalign cases than the vast majority of Queens practices — handling everything from minor crowding to complex bite issues.',
    },
  ]}
  faq={[
    {
      q: 'What is the most popular cosmetic dental treatment?',
      a: 'Teeth whitening is the most commonly requested cosmetic treatment — fast, affordable, and effective for most patients. For more significant changes to shape or structure, porcelain veneers and dental bonding are the most frequently chosen options. Invisalign is our most requested orthodontic cosmetic treatment.',
    },
    {
      q: 'How do I know which cosmetic treatment is right for me?',
      a: 'It depends on what you\'re looking to change. Discoloration → whitening or veneers. Chips or cracks → bonding or veneers. Alignment → Invisalign. Multiple concerns → smile design that combines treatments. We\'ll walk you through all options at your consultation and give you an honest recommendation based on what will actually achieve your goals.',
    },
    {
      q: 'Does cosmetic dentistry hurt?',
      a: 'Most cosmetic procedures are comfortable and require little or no anesthesia. Whitening may cause temporary sensitivity. Veneers require local anesthesia for preparation. Invisalign involves no drilling at all. We discuss comfort expectations for every procedure upfront.',
    },
    {
      q: 'Is cosmetic dentistry covered by insurance?',
      a: 'Most purely cosmetic procedures (whitening, veneers, bonding for aesthetic reasons) are not covered by dental insurance. However, some cosmetic treatments that also have functional benefits — like Invisalign for bite correction or bonding to repair a broken tooth — may receive partial coverage. We\'ll review your benefits and give you a clear cost breakdown before any treatment begins.',
    },
    {
      q: 'How long do cosmetic dental results last?',
      a: 'It depends on the treatment: Teeth whitening: 1–3 years with maintenance. Dental bonding: 5–10 years. Porcelain veneers: 15–20 years. Invisalign results: permanent with proper retainer use. All cosmetic work benefits from good oral hygiene, regular checkups, and avoiding habits like nail-biting or chewing ice.',
    },
  ]}
  related={[
    { href: '/services/preventive-dentistry',  label: 'Preventive Dentistry' },
    { href: '/services/restorative-dentistry', label: 'Restorative Dentistry' },
    { href: '/services',                       label: 'All Services' },
  ]}
  ctaHeading="Ready to transform your smile?"
>
  <section class="bg-white pb-12">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-brand-500 mb-6">Our Cosmetic Services</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a href={s.href} class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-brand-200 hover:shadow-md transition-all no-underline">
            <span class="text-sm font-semibold text-slate-700 group-hover:text-brand-500 transition-colors">{s.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 group-hover:text-brand-500 transition-colors shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</ServicePage>
