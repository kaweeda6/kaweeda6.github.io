---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CallBar from "../../components/CallBar.astro";
import { Image } from "astro:assets";
import { BOOK_APPOINTMENT_URL } from "../../data/site";

import preventiveImg from "../../assets/office/thrivedental-2750.jpg";
import cosmeticImg from "../../assets/office/dr_mik_showing_denturess.jpg";
import restorativeImg from "../../assets/office/dr_mik_looking_dentures.jpg";
import periodonticsImg from "../../assets/office/dr_mik_looking_xray.jpg";

const categories = [
  {
    title: 'Preventive Dentistry',
    href: '/services/preventive-dentistry',
    img: preventiveImg,
    desc: 'Cleanings, exams, sealants, fluoride, mouthguards, and pediatric care to keep your smile healthy for life.',
    services: ['Dental Cleanings & Exams', 'Pediatric Dentistry', 'Fluoride Treatment', 'Dental Sealants', 'Oral Cancer Screening', 'Mouthguards', 'Nightguards'],
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
  },
  {
    title: 'Cosmetic Dentistry',
    href: '/services/cosmetic-dentistry',
    img: cosmeticImg,
    desc: 'Teeth whitening, veneers, Invisalign®, and smile design to help you look and feel your best.',
    services: ['Teeth Whitening', 'Porcelain Veneers', 'Invisalign®', 'Dental Bonding', 'Smile Design'],
    icon: `<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="currentColor"/>`,
  },
  {
    title: 'Restorative Dentistry',
    href: '/services/restorative-dentistry',
    img: restorativeImg,
    desc: 'Implants, crowns, bridges, dentures, and full-mouth reconstruction to restore function and beauty.',
    services: ['Dental Implants', 'Dental Crowns', 'Dental Bridges', 'Root Canal Therapy', 'Dentures', 'Dental Fillings', 'Full-Mouth Reconstruction'],
    icon: `<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
  {
    title: 'Periodontics',
    href: '/services/periodontics',
    img: periodonticsImg,
    desc: 'Gum disease treatment, scaling & root planing, laser therapy, and iTero digital impressions.',
    services: ['Gum Disease Treatment', 'Periodontal Treatments', 'Laser Dentistry', 'iTero® Digital Impressions', 'Implant Restoration'],
    icon: `<path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>`,
  },
]
---

<Base
  title="Dental Services in Bayside, Queens NY | Thrive Dental"
  description="Comprehensive dental services in Bayside, Queens NY — preventive, cosmetic, restorative, and periodontal care. Board-certified dentists, same-day appointments. Call (718) 225-6677."
>
  <Fragment slot="header"><Header /></Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/3 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-brand-100/50 blur-[90px]"></div>
      <div class="absolute bottom-0 right-0 h-[320px] w-[320px] rounded-full bg-brand-50/80 blur-[70px]"></div>
    </div>
    <div class="container-slim text-center">
      <span class="mb-5 inline-block rounded-full bg-brand-100 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.25em] text-brand-700">All Services</span>
      <h1 class="display-1 mb-6">
        Comprehensive dental care<br class="hidden sm:block" /> in Bayside, Queens.
      </h1>
      <p class="mx-auto max-w-xl text-lg text-slate-500 leading-relaxed mb-9">
        From routine cleanings to full-mouth transformations — our board-certified team offers every service your smile needs, under one roof.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href={BOOK_APPOINTMENT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 hover:-translate-y-px transition-all no-underline"
        >
          Book Appointment
        </a>
        <a href="tel:+1-718-225-6677" class="inline-flex items-center gap-2 rounded-full border border-slate-300 bg-white px-6 py-3.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50 transition-all no-underline">(718) 225-6677</a>
      </div>
    </div>
  </section>

  <!-- Category Cards -->
  <section class="bg-sand-100 py-24 lg:py-32">
    <div class="container-slim">
      <div class="grid gap-8 sm:grid-cols-2">
        {categories.map((cat) => (
          <div class="group relative overflow-hidden rounded-[2.5rem] border border-brand-100/60 bg-white shadow-[0_4px_24px_rgba(0,0,0,0.05)] transition-all duration-500 hover:-translate-y-2 hover:border-brand-300/60 hover:shadow-[0_32px_64px_rgba(0,0,0,0.10)]">
            <!-- Card Image -->
            <div class="relative h-64 w-full overflow-hidden">
              <Image
                src={cat.img}
                alt={cat.title}
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                width={600}
                height={400}
                quality={90}
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
              
              <!-- Floating Icon -->
              <div class="absolute bottom-6 left-10 flex h-14 w-14 items-center justify-center rounded-2xl bg-white/20 text-white backdrop-blur-md ring-1 ring-white/30 transition-colors duration-300 group-hover:bg-brand-500 group-hover:text-white group-hover:ring-brand-500">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon}></svg>
              </div>
            </div>

            <!-- Content Area -->
            <div class="p-10">
              <h2 class="display-3 mb-3 group-hover:text-brand-500 transition-colors">{cat.title}</h2>
              <p class="text-[15px] leading-relaxed text-slate-500 mb-6">{cat.desc}</p>
              <ul class="space-y-1.5 mb-8">
                {cat.services.map((s) => (
                  <li class="flex items-center gap-2 text-sm text-slate-600">
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-400 shrink-0"></span>
                    {s}
                  </li>
                ))}
              </ul>
              <a href={cat.href} class="inline-flex items-center gap-2 text-sm font-bold text-brand-500 hover:text-brand-700 no-underline transition-colors">
                Explore {cat.title}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Emergency strip -->
      <div class="mt-8 flex flex-col gap-6 rounded-[2rem] bg-red-50 border border-red-100 p-8 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="relative flex h-3 w-3"><span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-red-400 opacity-75"></span><span class="relative inline-flex h-3 w-3 rounded-full bg-red-500"></span></span>
            <p class="text-[11px] font-black uppercase tracking-[0.25em] text-red-600">Emergency Care</p>
          </div>
          <h3 class="font-display text-xl font-bold text-slate-900">Dental emergency? We're here.</h3>
          <p class="text-sm text-slate-500 mt-1">Same-day appointments reserved daily for urgent needs.</p>
        </div>
        <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-2">
          <a href="/services/emergency-dentistry" class="inline-flex w-full items-center justify-center gap-2 rounded-full bg-red-600 px-6 py-3 text-sm font-bold text-white hover:bg-red-700 transition-colors no-underline sm:w-auto">Emergency Info</a>
          <a href="tel:+1-718-225-6677" class="inline-flex w-full items-center justify-center gap-2 rounded-full border border-red-200 px-6 py-3 text-sm font-semibold text-red-700 hover:bg-red-100 transition-colors no-underline sm:w-auto">(718) 225-6677</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-brand-700">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 -right-20 h-[300px] w-[300px] rounded-full bg-brand-500/20 blur-[60px]"></div>
      <div class="absolute -bottom-20 -left-20 h-[300px] w-[300px] rounded-full bg-brand-500/10 blur-[60px]"></div>
    </div>
    <div class="container-slim relative py-12 text-center">
      <h2 class="display-3 !text-white mb-4">Not sure where to start?</h2>
      <p class="mt-3 text-white/80 mx-auto max-w-md text-[15px]">Book a consultation and our doctors will create a personalized treatment plan for your smile.</p>
      <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={BOOK_APPOINTMENT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 hover:-translate-y-px transition-all no-underline"
        >
          Book a Consultation
        </a>
        <a href="tel:+1-718-225-6677" class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3.5 text-sm font-semibold text-white hover:bg-white/10 transition-all no-underline">(718) 225-6677</a>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
