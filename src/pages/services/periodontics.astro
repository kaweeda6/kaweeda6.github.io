---
import ServicePage from "../../layouts/ServicePage.astro";
import heroImg from "../../assets/office/dr_mik_looking_xray.jpg";
const services = [
  { href: '/services/gum-disease-treatment',     label: 'Gum Disease Treatment' },
  { href: '/services/periodontal-treatments',    label: 'Periodontal Treatments' },
  { href: '/services/laser-dentistry',           label: 'Laser Dentistry' },
  { href: '/services/itero-digital-impressions', label: 'iTero® Digital Impressions' },
  { href: '/services/implant-restoration',       label: 'Implant Restoration' },
]
---
<ServicePage
  title="Periodontics & Gum Care in Bayside, Queens NY | Thrive Dental"
  description="Periodontal care in Bayside, Queens NY — gum disease treatment, scaling & root planing, laser dentistry, and iTero digital impressions. Expert gum care. Call (718) 225-6677."
  category="Our Services"
  categoryHref="/services"
  h1="Periodontics & Gum Care in Bayside, NY"
  subtitle="Healthy gums are the foundation of a healthy smile. Our periodontal treatments address gum disease at every stage — from early gingivitis to advanced periodontitis."
  heroImg={heroImg}
  related={[
    { href: '/services/restorative-dentistry', label: 'Restorative Dentistry' },
    { href: '/services/preventive-dentistry',  label: 'Preventive Dentistry' },
    { href: '/services',                       label: 'All Services' },
  ]}
>
  <section class="bg-white py-20">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-6">Periodontal Services</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a href={s.href} class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-brand-200 hover:shadow-md transition-all no-underline">
            <span class="text-sm font-semibold text-slate-700 group-hover:text-brand-500 transition-colors">{s.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 group-hover:text-brand-500 transition-colors shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</ServicePage>
