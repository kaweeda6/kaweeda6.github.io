---
import ServicePage from "../../layouts/ServicePage.astro";
import heroImg from "../../assets/office/thrivedental-2750.jpg";
const services = [
  { href: '/services/dental-cleanings',      label: 'Dental Cleanings & Exams' },
  { href: '/services/pediatric-dentistry',   label: 'Pediatric Dentistry' },
  { href: '/services/fluoride-treatment',    label: 'Fluoride Treatment' },
  { href: '/services/dental-sealants',       label: 'Dental Sealants' },
  { href: '/services/oral-cancer-screening', label: 'Oral Cancer Screening' },
  { href: '/services/mouthguards',           label: 'Mouthguards' },
  { href: '/services/nightguards',           label: 'Nightguards' },
]
---
<ServicePage
  title="Preventive Dentistry in Bayside, Queens NY | Thrive Dental"
  description="Preventive dental care in Bayside, Queens NY — cleanings, exams, fluoride, sealants, and pediatric dentistry. Keep your smile healthy for life. Call (718) 225-6677."
  category="Our Services"
  categoryHref="/services"
  h1="Preventive Dentistry in Bayside, NY"
  subtitle="Protecting your natural teeth for a lifetime. Gentle cleanings, digital X-rays, and comprehensive exams to keep your teeth and gums in peak condition."
  heroImg={heroImg}
  heroImgPosition="50%"
  overviewTitle="What is preventive dentistry — and why does it matter?"
  overviewText="Preventive dentistry is the practice of caring for your teeth and gums proactively to avoid disease before it starts. It encompasses professional cleanings, comprehensive exams, fluoride treatments, dental sealants, oral cancer screenings, and custom-fitted guards that protect your teeth from grinding and sports injuries. The core principle is straightforward: catching a problem early is always less invasive, less expensive, and less disruptive than treating it after it has progressed. A small cavity treated with a simple filling costs a fraction of the crown or root canal it becomes if ignored. Gingivitis caught at a routine cleaning requires nothing more than improved hygiene — while periodontitis, its advanced form, requires deep cleanings, laser therapy, or surgery."
  overviewExtra="The American Dental Association recommends professional cleanings and exams at least twice per year for most patients — and more frequently (every 3–4 months) for those managing gum disease, high cavity rates, dry mouth, or other risk factors. At Thrive Dental in Bayside, our preventive program is built around each patient's individual risk profile, not a one-size-fits-all schedule. We use digital X-rays (90% less radiation than traditional film), periodontal probing at every visit, intraoral cameras to show you exactly what we see, and VELscope fluorescence technology for oral cancer screening. Families from Bayside, Flushing, Whitestone, Little Neck, and Douglaston rely on us for consistent, thorough preventive care — and our hygiene team never rushes through an appointment to fit in more patients."
  benefits={[
    {
      icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
      title: 'Catch Problems Early',
      desc: 'A small cavity, a gum pocket that\'s deepening, a suspicious soft tissue lesion — caught at a routine visit, all of these are simple to address. Left undetected, they become complex, costly problems.',
    },
    {
      icon: `<circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>`,
      title: 'Preserve Natural Teeth',
      desc: 'Nothing we can place is as good as your natural tooth. Preventive care is the most effective strategy for keeping your original teeth healthy into old age.',
    },
    {
      icon: `<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>`,
      title: 'Protect Whole-Body Health',
      desc: 'Oral health is directly connected to cardiovascular disease, diabetes management, and pregnancy outcomes. Preventive dental care is an investment in your overall health.',
    },
    {
      icon: `<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>`,
      title: 'Lower Lifetime Costs',
      desc: 'Patients who attend regular preventive visits spend significantly less on dental care over their lifetimes than those who only seek treatment when something hurts.',
    },
  ]}
  faq={[
    {
      q: 'How often should I see the dentist for preventive care?',
      a: 'Most healthy adults benefit from professional cleanings and exams every six months. Patients with active gum disease, a history of frequent cavities, dry mouth, or systemic conditions like diabetes may need visits every 3–4 months. We determine your recall interval based on clinical findings, not a blanket policy.',
    },
    {
      q: 'What does a preventive dental visit include?',
      a: 'A full preventive visit at Thrive Dental includes: professional scaling and polishing by our hygienist, digital X-rays (when due), periodontal pocket measurements, a comprehensive exam by the doctor, oral cancer screening, and a personalized home care review. New patient exams also include full-mouth X-rays and a thorough medical history review.',
    },
    {
      q: 'Are preventive dental services covered by insurance?',
      a: 'Most dental insurance plans cover two preventive visits per year at 100% — no copay, no deductible. This typically includes cleanings, exams, and X-rays. Fluoride treatments and sealants are often covered for children; coverage for adults varies. We verify your benefits before every appointment.',
    },
    {
      q: 'What can I do at home to support preventive care?',
      a: 'Brush for two full minutes twice daily with a fluoride toothpaste. Floss or use an interdental brush once daily. Limit sugary and acidic foods and drinks. Stay hydrated — dry mouth accelerates decay. Replace your toothbrush every 3 months. And attend your scheduled cleanings consistently.',
    },
    {
      q: 'Is preventive care important for children?',
      a: 'Critically so. Baby teeth hold space for adult teeth, aid in speech development, and affect nutrition. The American Academy of Pediatric Dentistry recommends the first dental visit by age 1. Early preventive visits establish healthy habits, allow us to apply fluoride and sealants, and catch developmental issues before they require complex intervention.',
    },
  ]}
  related={[
    { href: '/services/cosmetic-dentistry',    label: 'Cosmetic Dentistry' },
    { href: '/services/restorative-dentistry', label: 'Restorative Dentistry' },
    { href: '/services',                       label: 'All Services' },
  ]}
  ctaHeading="Your healthiest smile starts with prevention."
>
  <section class="bg-white pb-12">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-brand-500 mb-6">Our Preventive Services</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a href={s.href} class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-brand-200 hover:shadow-md transition-all no-underline">
            <span class="text-sm font-semibold text-slate-700 group-hover:text-brand-500 transition-colors">{s.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 group-hover:text-brand-500 transition-colors shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</ServicePage>
