---
import ServicePage from "../../layouts/ServicePage.astro";
import heroImg from "../../assets/office/thrivedental-2750.jpg";
const services = [
  { href: '/services/dental-cleanings',      label: 'Dental Cleanings & Exams' },
  { href: '/services/pediatric-dentistry',   label: 'Pediatric Dentistry' },
  { href: '/services/fluoride-treatment',    label: 'Fluoride Treatment' },
  { href: '/services/dental-sealants',       label: 'Dental Sealants' },
  { href: '/services/oral-cancer-screening', label: 'Oral Cancer Screening' },
  { href: '/services/mouthguards',           label: 'Mouthguards' },
  { href: '/services/nightguards',           label: 'Nightguards' },
]
---
<ServicePage
  title="Preventive Dentistry in Bayside, Queens NY | Thrive Dental"
  description="Preventive dental care in Bayside, Queens NY — cleanings, exams, fluoride, sealants, and pediatric dentistry. Keep your smile healthy for life. Call (718) 225-6677."
  category="Our Services"
  categoryHref="/services"
  h1="Preventive Dentistry in Bayside, NY"
  subtitle="Protecting your natural teeth for a lifetime. Gentle cleanings, digital X-rays, and comprehensive exams to keep your teeth and gums in peak condition."
  heroImg={heroImg}
  related={[
    { href: '/services/cosmetic-dentistry',    label: 'Cosmetic Dentistry' },
    { href: '/services/restorative-dentistry', label: 'Restorative Dentistry' },
    { href: '/services',                       label: 'All Services' },
  ]}
>
  <section class="bg-white py-20">
    <div class="container-slim">
      <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-6">Preventive Services</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <a href={s.href} class="group flex items-center justify-between rounded-2xl border border-slate-100 bg-white p-6 shadow-sm hover:border-brand-200 hover:shadow-md transition-all no-underline">
            <span class="text-sm font-semibold text-slate-700 group-hover:text-brand-500 transition-colors">{s.label}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-slate-300 group-hover:text-brand-500 transition-colors shrink-0"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>
</ServicePage>
