---
import ServicePage from "../../layouts/ServicePage.astro";
import heroImg from "../../assets/office/thrivedental-2750.jpg";
---
<ServicePage
  title="Financial Information | Thrive Dental Bayside, NY"
  description="Dental payment options at Thrive Dental Bayside, Queens NY — we accept most insurance, cash, credit cards, and offer CareCredit financing. Call (718) 225-6677."
  category="New Patients"
  categoryHref="/new-patients"
  h1="Flexible Payment Options at Thrive Dental"
  subtitle="We believe quality dental care should be accessible. We accept most major insurance plans, offer CareCredit financing, and will file insurance claims on your behalf."
  heroImg={heroImg}
  overviewTitle="Accessible care for every patient."
  showWhyThrive={false}
  related={[
    { href: '/new-patients/insurance',  label: 'Insurance We Accept' },
    { href: '/new-patients/first-visit', label: 'Your First Visit' },
    { href: '/contact',                  label: 'Contact Us' },
  ]}
>
  <section class="bg-white py-20 lg:py-28">
    <div class="container-slim space-y-16">

      <div class="grid gap-12 lg:grid-cols-[1.1fr_.9fr]">
        <div>
          <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-4">Financial Information</p>
          <h2 class="display-2 mb-6">Transparent costs. Options that fit your life.</h2>
          <p class="text-[17px] leading-relaxed text-slate-500 mb-6">
            The cost of treatment varies based on your personalized plan. Before we begin, we review every recommended procedure, outline the total investment, and present the payment pathways available so you can make the choice that feels right.
          </p>
          <div class="space-y-4">
            {[
              'Most major PPO insurance plans accepted',
              'Visa, MasterCard, American Express, Discover, HSA, and FSA cards welcome',
              'CareCredit® financing, including promotional no-interest options for qualified patients',
              'Custom in-office payment arrangements for larger treatment plans',
            ].map((item) => (
              <div class="flex gap-3 items-start">
                <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-600">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <p class="text-[15px] leading-relaxed text-slate-600">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-slate-50/60 p-8 shadow-[0_10px_40px_rgba(15,23,42,0.06)]">
          <h3 class="text-lg font-semibold text-slate-900 mb-4">Insurance guidance, every step.</h3>
          <p class="text-[15px] leading-relaxed text-slate-600 mb-5">
            Our treatment coordinators handle claims, pre-authorizations, and benefits breakdowns for you. Bring your insurance card to your visit (or email it ahead) and we'll verify coverage, estimate out-of-pocket costs, and submit paperwork directly to your provider.
          </p>
          <p class="text-[14px] text-slate-500">
            Questions about coverage? Call <a href="tel:+1-718-225-6677" class="text-brand-600 font-semibold no-underline">(718) 225-6677</a> or email <a href="mailto:info@thrivedentalny.com" class="text-brand-600 font-semibold no-underline">info@thrivedentalny.com</a> and we'll walk you through the details before your appointment.
          </p>
        </div>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <div class="rounded-[2rem] border border-brand-100 bg-white p-8 shadow-[0_12px_40px_rgba(17,24,39,0.06)]">
          <div class="mb-5">
            <span class="inline-flex items-center gap-2 rounded-full bg-brand-50 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.2em] text-brand-700">In-House Plan</span>
          </div>
          <h3 class="text-2xl font-display text-slate-900 mb-4">Roslyn Discount Dental Plan</h3>
          <p class="text-[15px] leading-relaxed text-slate-600 mb-5">
            No insurance? Our in-house membership includes two preventive cleanings per year, routine exams, X-rays as needed, and exclusive discounts on restorative, periodontal, and cosmetic care for one annual fee.
          </p>
          <ul class="space-y-3 text-[14px] text-slate-600 mb-6">
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-400"></span>15% or more savings on most treatments</li>
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-400"></span>No waiting periods, deductibles, or yearly maximums</li>
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-brand-400"></span>Available for individuals and families</li>
          </ul>
          <a
            href="https://app.dentalhq.com/accounts/signup/my-dentist/8074"
            class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 no-underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            View plan & enroll ↗
          </a>
        </div>

        <div class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-[0_12px_40px_rgba(17,24,39,0.05)]">
          <div class="mb-5">
            <span class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.2em] text-slate-600">CareCredit® Financing</span>
          </div>
          <h3 class="text-2xl font-display text-slate-900 mb-4">Break treatment into monthly payments.</h3>
          <p class="text-[15px] leading-relaxed text-slate-600 mb-5">
            Use CareCredit to finance preventive visits, Invisalign®, implants, smile makeovers, and more. Many plans feature zero-interest financing when paid within the promotional period.
          </p>
          <ul class="space-y-3 text-[14px] text-slate-600 mb-6">
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-slate-400"></span>Instant decisions in most cases</li>
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-slate-400"></span>Use for the whole family</li>
            <li class="flex items-start gap-2"><span class="mt-1 h-1.5 w-1.5 rounded-full bg-slate-400"></span>Accepted at thousands of health + wellness offices</li>
          </ul>
          <div class="flex flex-wrap gap-3">
            <a
              href="/downloads/carecredit-application.pdf"
              class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 no-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Download application (PDF)
            </a>
            <a
              href="https://www.carecredit.com/apply/"
              class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-5 py-3 text-sm font-bold text-white shadow-md hover:bg-brand-400 no-underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Apply online ↗
            </a>
          </div>
        </div>
      </div>

      <div class="rounded-[2rem] border border-slate-200 bg-slate-50/80 p-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-start lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-[11px] font-black uppercase tracking-[0.25em] text-gold-700 mb-3">Convenient Online Services</p>
            <h3 class="text-2xl font-display text-slate-900 mb-4">Access your account anywhere.</h3>
            <p class="text-[15px] leading-relaxed text-slate-600">
              Our secure patient portal lets you manage appointments, payments, and reminders 24/7. Ask our front desk to set up your login during your next visit and we'll email a link with instructions.
            </p>
          </div>
          <div class="grid gap-3 text-[14px] text-slate-600">
            {[
              'View upcoming appointments and account balances',
              'Sign up for email or text reminders',
              'Review payment history and current charges',
              'Download FSA/HSA reimbursement or tax receipts',
            ].map((item) => (
              <div class="flex gap-3">
                <div class="mt-1 flex h-4 w-4 items-center justify-center rounded-full bg-brand-500/10 text-brand-600">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span>{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>
</ServicePage>
