---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import CallBar from "../../components/CallBar.astro";
import { BOOK_APPOINTMENT_URL } from "../../data/site";

const links = [
  { href: '/new-patients/first-visit',           title: 'Your First Visit', desc: 'What to expect, what to bring, and how long your appointment will take.' },
  { href: '/new-patients/financial-information',  title: 'Financial Information', desc: 'Payment options, accepted insurance, and CareCredit financing.' },
  { href: '/new-patients/insurance',              title: 'Insurance We Accept', desc: 'We work with most major dental insurance plans and will file claims on your behalf.' },
  { href: 'https://forms.nexhealth.com/patient/ThriveDental', title: 'Patient Forms ↗', desc: 'Complete your new patient paperwork online before your visit — saves time at the office.', external: true },
]
---

<Base
  title="New Patients | Thrive Dental Bayside, Queens NY"
  description="New to Thrive Dental in Bayside, Queens? Find everything you need — first visit info, patient forms, insurance details, and financial options. Call (718) 225-6677."
>
  <Fragment slot="header"><Header /></Fragment>

  <section class="relative overflow-hidden bg-sand-50" style="padding-top: clamp(6rem, 12vw, 9rem); padding-bottom: clamp(3rem, 6vw, 5rem);">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/3 h-[520px] w-[520px] -translate-x-1/2 rounded-full bg-brand-100/50 blur-[90px]"></div>
    </div>
    <div class="container-slim text-center">
      <span class="mb-5 inline-block rounded-full bg-brand-100 px-4 py-1.5 text-[11px] font-black uppercase tracking-[0.25em] text-brand-700">Welcome</span>
      <h1 class="display-1 mb-6">New to Thrive Dental?</h1>
      <p class="mx-auto max-w-xl text-lg text-slate-500 leading-relaxed">We're so glad you're here. Everything you need to prepare for your first visit is right below.</p>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="container-slim">
      <div class="grid gap-6 sm:grid-cols-2">
        {links.map((l) => (
          <a
            href={l.href}
            target={l.external ? '_blank' : undefined}
            rel={l.external ? 'noopener noreferrer' : undefined}
            class="group flex flex-col justify-between rounded-[2rem] border border-slate-100 bg-white p-8 shadow-sm hover:border-brand-200 hover:shadow-lg transition-all no-underline"
          >
            <div>
              <h2 class="font-display text-xl font-bold text-slate-900 mb-3 group-hover:text-brand-600 transition-colors">{l.title}</h2>
              <p class="text-sm text-slate-500 leading-relaxed">{l.desc}</p>
            </div>
            <div class="mt-6 flex items-center gap-2 text-sm font-bold text-brand-600">
              Learn more
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-brand-700">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute -top-20 -right-20 h-[300px] w-[300px] rounded-full bg-brand-500/20 blur-[60px]"></div>
    </div>
    <div class="container-slim relative py-12 text-center">
      <h2 class="display-3 !text-white mb-4">Ready to book your first visit?</h2>
      <p class="text-white/80 max-w-md mx-auto mb-8">New patients are always welcome — no referral needed. We'll take care of the rest.</p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={BOOK_APPOINTMENT_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-full bg-brand-500 px-6 py-3.5 text-sm font-bold text-white shadow-lg shadow-brand-500/20 hover:bg-brand-400 transition-all no-underline"
        >
          Book Appointment
        </a>
        <a href="tel:+1-718-225-6677" class="inline-flex items-center gap-2 rounded-full border border-white/30 px-6 py-3.5 text-sm font-semibold text-white hover:bg-white/10 transition-all no-underline">(718) 225-6677</a>
      </div>
    </div>
  </section>

  <Fragment slot="footer"><Footer /></Fragment>
  <CallBar />
</Base>
