---
import { Image } from "astro:assets";

// Local imports for optimized images
import resFullArch from "../assets/results/full-arch-restoration.jpg";
import resFunctional from "../assets/results/functional-rejuvenation.jpg";
import resSmile from "../assets/results/smile-makeover.jpg";
import resRestorative from "../assets/results/restorative-excellence.jpg";
import resComplex from "../assets/results/complex-case-design.png";

const transformations = [
  {
    img: resFullArch,
    title: 'Full Arch Restoration',
    detail: 'Complete functional and aesthetic reconstruction using advanced porcelain ceramics.',
    slug: 'full-arch-restoration',
    nudge: { x: '2.2%', y: '4.8%', scale: '1.09' } // Initial alignment fix for Full Arch
  },
  {
    img: resFunctional,
    title: 'Functional Rejuvenation',
    detail: 'Restoring bite alignment and structural integrity while enhancing natural brightness.',
    slug: 'functional-rejuvenation',
    nudge: { x: '0%', y: '1%', scale: '1.02' }
  },
  {
    img: resSmile,
    title: 'Smile Makeover',
    detail: 'Correcting spacing and discoloration for a perfectly symmetrical, radiant result.',
    slug: 'smile-makeover',
    nudge: { x: '0.8%', y: '1.2%', scale: '1.04' }
  },
  {
    img: resRestorative,
    title: 'Restorative Excellence',
    detail: 'Precision crown and bridge work to restore lost confidence and oral health.',
    slug: 'restorative-excellence',
    nudge: { x: '-0.5%', y: '2.5%', scale: '1.05' }
  },
  {
    img: resComplex,
    title: 'Complex Case Design',
    detail: 'A multi-disciplinary approach to resolving complex aesthetic and health concerns.',
    slug: 'complex-case-design',
  },
]
---

<section class="relative bg-white pt-16 pb-28 lg:pt-20 lg:pb-36 overflow-hidden">
  <div class="container-wide relative">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-10 mb-10">
      <div class="max-w-2xl">
        <p class="text-[12px] font-black uppercase tracking-[0.2em] text-brand-500 mb-4">Smile Transformations</p>
        <h2 class="display-1 text-slate-900 mb-6">Proof in every before & after.</h2>
        <p class="text-lg text-slate-500 leading-relaxed italic font-serif">
          Explore real Thrive Dental cases—from single-tooth fixes to full-arch rehabilitation—crafted with digital planning, meticulous aesthetics, and a focus on long-term function.
        </p>
      </div>
      <div class="shrink-0">
        <div class="flex items-center gap-4 text-slate-400 text-sm font-medium border-b border-slate-200 pb-2">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12H3m18 0-4-4m4 4-4 4"/></svg>
          Slide to reveal transformation
        </div>
      </div>
    </div>

    <!-- Gallery Grid -->
    <div class="grid gap-6 lg:grid-cols-2">
      {transformations.map((t, i) => (
        <div class="group relative flex flex-col">
          <!-- Case Info -->
          <div class="mb-6">
            <h3 class="display-3 group-hover:text-brand-700 transition-colors">{t.title}</h3>
            <p class="mt-2 text-slate-500 text-sm max-w-sm leading-relaxed">{t.detail}</p>
            <a href={`/before-and-after/${t.slug}`} class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-700 transition-colors no-underline">
              View Case Study
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- Slider Container -->
          <div class="before-after-container relative aspect-[2/1.1] w-full overflow-hidden rounded-[1.5rem] bg-slate-200 shadow-xl group/slider">
            
            <!-- Layer 1: AFTER (Bottom) -->
            <div class="absolute inset-0 h-full w-full">
              <Image 
                src={t.img} 
                alt={`${t.title} After`}
                class="absolute bottom-0 h-[200%] w-full object-cover grayscale-0"
                width={800}
                height={880}
              />
              <div class="absolute bottom-4 right-4 rounded-full bg-brand-500 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white shadow-lg z-10">
                After
              </div>
            </div>

            <!-- Layer 2: BEFORE (Top) -->
            <div class="before-layer absolute inset-0 h-full w-1/2 overflow-hidden border-r-2 border-white z-20">
              <div class="absolute inset-0 h-full w-[200%] before-image-wrapper" style="width: 200%;">
                <Image 
                  src={t.img} 
                  alt={`${t.title} Before`}
                  class="absolute top-0 h-[200%] w-full object-cover grayscale-[0.05]"
                  style={t.nudge ? `transform: translate(${t.nudge.x}, ${t.nudge.y}) scale(${t.nudge.scale}); transform-origin: center center;` : ''}
                  width={800}
                  height={880}
                />
              </div>
              <div class="absolute bottom-4 left-4 rounded-full bg-slate-900/80 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white backdrop-blur-md">
                Before
              </div>
            </div>

            <!-- Slider Handle -->
            <div class="slider-handle absolute top-0 bottom-0 left-1/2 z-30 flex w-0.5 -translate-x-1/2 items-center justify-center bg-white">
               <div class="flex h-10 w-10 items-center justify-center rounded-full bg-white shadow-xl text-brand-500 cursor-ew-resize transition-transform group-hover/slider:scale-110">
                 <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                   <path d="m18 8 4 4-4 4M6 8l-4 4 4 4"/>
                 </svg>
               </div>
            </div>

            <input 
              type="range" 
              min="0" 
              max="100" 
              value="50" 
              class="absolute inset-0 z-40 h-full w-full cursor-ew-resize opacity-0" 
              aria-label="Before and after slider" 
            />
          </div>
        </div>
      ))}
    </div>
  </div>
  <!-- Wave into CTA/Reviews (brand-800) -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none pointer-events-none">
    <svg viewBox="0 0 1440 48" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="height:48px;display:block;width:100%">
      <path d="M0,24 C240,48 480,0 720,24 C960,48 1200,0 1440,24 L1440,48 L0,48 Z" fill="#5cc9be"/>
    </svg>
  </div>
</section>


<style>
  .before-after-container input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
  }
</style>

<script>
  function initStudioSliders() {
    const containers = document.querySelectorAll('.before-after-container');
    
    containers.forEach(container => {
      const input = container.querySelector('input') as HTMLInputElement;
      const beforeLayer = container.querySelector('.before-layer') as HTMLElement;
      const beforeWrapper = container.querySelector('.before-image-wrapper') as HTMLElement;
      const handle = container.querySelector('.slider-handle') as HTMLElement;

      if (input && beforeLayer && beforeWrapper && handle) {
        const updateSlider = () => {
          const val = Number(input.value);
          const pct = `${val}%`;
          
          // The layer itself shrinks/grows
          beforeLayer.style.width = pct;
          
          // The handle moves
          handle.style.left = pct;
          
          // IMPORTANT: The inner image wrapper must be sized relative to the container width,
          // not the shrinking beforeLayer. Since beforeLayer width is X%, the wrapper
          // needs to be (100 / X) * 100% to remain exactly 100% of the container.
          if (val > 0) {
            const inversePct = (100 / val) * 100;
            beforeWrapper.style.width = `${inversePct}%`;
          } else {
            beforeWrapper.style.width = '10000%';
          }
        };
        
        input.addEventListener('input', updateSlider);
        // Initial set
        updateSlider();
      }
    });
  }

  initStudioSliders();
  document.addEventListener('astro:after-swap', initStudioSliders);
</script>
