---
const siteUrl = 'https://www.thrivedentalny.com'
const testimonials = [
  { text: "Super caring and gentle.", name: "Jennifer O.", location: "Bayside, NY", rating: 5 },
  { text: "The best.", name: "Loic C.", location: "Bayside, NY", rating: 5 },
  { text: "It was a pleasure being at a dentist office that takes their time.", name: "Melissa H.", location: "Bayside, NY", rating: 5 },
  { text: "Always excellent. Extremely beautiful office, friendly professional staff. All (3) dentists I've seen were great. Absolutely no pain whatsoever.", name: "Leslie G.", location: "Bayside, NY", rating: 5 },
  { text: "Excellent care and good advice and support.", name: "Steven M.", location: "Bayside, NY", rating: 5 },
  { text: "Friendly doctor and nurses. Very sympathetic. Spotless office.", name: "Edward H.", location: "Bayside, NY", rating: 5 },
  { text: "I was seen by one of her associate dentists and he was very professional. The entire staff was wonderful. The hygienist was gentle and thorough … happy to have found this office conveniently on Bell Blvd.", name: "Louisa C.", location: "Bayside, NY", rating: 5 },
  { text: "I really enjoyed my dental appointment with Dr. Hart. She is so caring and calm … I will definitely be a lifelong patient.", name: "Christopher Z.", location: "Bayside, NY", rating: 5 },
  { text: "Friendly, encouraging, and nice to my son when he had his first check up at the clinic.", name: "Raenan H.", location: "Bayside, NY", rating: 5 },
  { text: "Great experience. The office is clean and very modern, the staff is professional and they give great care making you feel very comfortable.", name: "Donna-Mari P.", location: "Bayside, NY", rating: 5 },
  { text: "She is the best … always warm and welcoming and sweet and caring … highly recommend her.", name: "Angela G.", location: "Bayside, NY", rating: 5 },
  { text: "Clean modern office with nice staff … they quickly resolved the online appointment scheduling.", name: "Jiehao Y.", location: "Bayside, NY", rating: 5 },
  { text: "I highly recommend Thrive Dental … Dr. Mikhaylova and staff provide a warm and friendly environment … professional and thorough.", name: "Vito M.", location: "Bayside, NY", rating: 5 },
  { text: "Warm vibes. Professional. Very friendly. 10/10 recommend.", name: "Lucas L.", location: "Bayside, NY", rating: 5 },
  { text: "Very nice and friendly staff. Made me feel very comfortable and addressed my issues right away.", name: "Mona P.", location: "Bayside, NY", rating: 5 },
]
---

<div>
  <!-- Top: brand-800 deep teal — CTA slot + reviews header -->
  <div class="relative bg-brand-800 pb-16 overflow-hidden">
    <slot name="cta" />
    <div class="container-slim mb-10 pt-10 text-center">
      <p class="text-[11px] font-bold uppercase tracking-[0.14em] text-brand-400">Patient Reviews</p>
      <h2 class="display-2 mt-2 !text-white">What patients are saying</h2>
      <div class="mt-2 flex items-center justify-center gap-2 text-[13px] text-white/50">
        <span class="text-amber-400">★★★★★</span>
        <span>4.9 out of 5 · 500+ Google reviews</span>
      </div>
    </div>
    <!-- Bright teal wave into carousel -->
    <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none pointer-events-none">
      <svg viewBox="0 0 1440 48" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="height:48px;display:block;width:100%">
        <path d="M0,24 C240,0 480,48 720,24 C960,0 1200,48 1440,24 L1440,48 L0,48 Z" fill="#3a928a"/>
      </svg>
    </div>
  </div>

  <!-- Bottom: brand-700 teal — carousel -->
  <section class="bg-brand-700 overflow-hidden pt-12 pb-16 sm:pb-20">
    <div class="relative overflow-hidden">
      <!-- Fades -->
      <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-brand-700 to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-brand-700 to-transparent"></div>

      <div class="marquee-reviews flex w-max gap-6 px-6">
        {[...testimonials, ...testimonials].map((t) => (
          <blockquote class="flex min-w-[320px] max-w-[320px] shrink-0 flex-col rounded-2xl border border-white/10 bg-white/[0.06] p-6 backdrop-blur-sm">
            <div class="flex gap-0.5 text-amber-400 text-[13px]">{'★'.repeat(t.rating)}</div>
            <p class="mt-3 flex-1 text-[15px] leading-relaxed text-white/85">"{t.text}"</p>
            <footer class="mt-6 flex items-center gap-3">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-800/60 text-sm font-bold text-brand-300">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="text-[13px] font-semibold text-white">{t.name}</p>
                <p class="text-[11px] text-white/70">{t.location}</p>
              </div>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>
</div>

<!-- JSON-LD: Review schema — enables star snippets in search results -->
<script type="application/ld+json" set:html={JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': testimonials.map((t) => ({
    '@type': 'Review',
    author: { '@type': 'Person', name: t.name },
    reviewRating: { '@type': 'Rating', ratingValue: t.rating, bestRating: 5 },
    reviewBody: t.text,
    itemReviewed: {
      '@type': 'Dentist',
      '@id': siteUrl + '/#dentist',
      name: 'Thrive Dental',
    },
  })),
})} />

<style>
  .marquee-reviews {
    animation: marquee 40s linear infinite;
    width: max-content;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Pause on hover */
  .marquee-reviews:hover {
    animation-play-state: paused;
  }
</style>
