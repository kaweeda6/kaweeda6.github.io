---
// Mobile bottom call-to-action bar (shows on small screens)
import { BOOK_APPOINTMENT_URL } from "../data/site"

const phone = '+1-718-225-6677'
const mapUrl = 'https://maps.app.goo.gl/yz2gipKBB3Dfp7Tg9'
---
<nav class="fixed inset-x-0 bottom-0 z-40 block border-t border-slate-200 bg-white/95 backdrop-blur md:hidden" aria-label="Quick actions" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
  <div class="mx-auto flex max-w-5xl items-stretch divide-x divide-slate-200 text-sm">
    <a href={`tel:${phone}`} class="flex w-1/3 items-center justify-center gap-2 p-3 text-slate-600 no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500">
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.09 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.81.3 1.6.57 2.35a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.73-1.73a2 2 0 0 1 2.11-.45c.75.27 1.54.45 2.35.57A2 2 0 0 1 22 16.92z"/></svg>
      <span>Call</span>
    </a>
    <a href={mapUrl} class="flex w-1/3 items-center justify-center gap-2 p-3 text-slate-600 no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-500">
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 1 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>Directions</span>
    </a>
    <a href={BOOK_APPOINTMENT_URL} target="_blank" rel="noopener noreferrer" class="flex w-1/3 items-center justify-center gap-2 p-3 bg-brand-500 text-white font-bold no-underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
      <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <span>Book</span>
    </a>
  </div>
</nav>
