---
---
<section class="bg-white py-24 lg:py-32 overflow-hidden">
  <div class="container-slim">
    <div class="max-w-2xl mb-16">
      <p class="text-[12px] font-black uppercase tracking-[0.2em] text-gold-700 mb-4">Our Environment</p>
      <h2 class="display-1 text-slate-900 mb-6">Designed for your comfort.</h2>
      <p class="text-lg text-slate-500 leading-relaxed">
        Step into a modern dental boutique where technology meets tranquility. Every detail of our Bayside office is curated to ensure a stress-free experience.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-4 md:grid-rows-3 gap-4 h-[1200px] md:h-[800px]">
      
      <!-- Main Office Image (2x2) -->
      <div class="md:col-span-2 md:row-span-2 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2057.jpg" 
          alt="Thrive Dental Bayside Office" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-black/5"></div>
      </div>

      <!-- Treatment Room Detail (1x2) -->
      <div class="md:col-span-1 md:row-span-2 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-3059.jpg" 
          alt="Modern dental technology" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <!-- Waiting Area (1x1) -->
      <div class="md:col-span-1 md:row-span-1 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2386.jpg" 
          alt="Comfortable seating" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <!-- Tech Detail (1x1) -->
      <div class="md:col-span-1 md:row-span-1 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2616.jpg" 
          alt="Digital care" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <!-- Corridor / Wide View (2x1) -->
      <div class="md:col-span-2 md:row-span-1 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2750.jpg" 
          alt="Office corridor" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <!-- Entryway / Desk (1x1) -->
      <div class="md:col-span-1 md:row-span-1 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2362.jpg" 
          alt="Welcome desk" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <!-- Tooling / Clinical (1x1) -->
      <div class="md:col-span-1 md:row-span-1 relative overflow-hidden rounded-[2.5rem] bg-slate-100 group">
        <img 
          src="/office/thrivedental-2650.jpg" 
          alt="Clinical precision" 
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

    </div>
  </div>
</section>
